<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <Platforms>AnyCPU;x64</Platforms>
  </PropertyGroup>

  <Target Name="KillRunningTradingDashboard" BeforeTargets="BeforeBuild">
    <Exec Command="taskkill /F /IM TradingDashboard.exe &gt;nul 2&gt;&amp;1" IgnoreExitCode="true" />
  </Target>

</Project>
