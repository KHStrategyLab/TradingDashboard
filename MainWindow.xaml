                                                        Text="{Binding VolumeText}"
                                                        FontSize="12"
                                                        Foreground="#A0A0A0"
                                                        TextTrimming="CharacterEllipsis"/>
                                             <TextBlock Grid.Column="1"
                                                        Text="{Binding TodayTradeValueText}"
                                                        FontSize="12"
                                                        FontWeight="Bold"
                                                        Margin="8,0,0,0"
                                                        TextAlignment="Right">
                                                 <TextBlock.Style>
                                                     <Style TargetType="TextBlock">
                                                         <Setter Property="Foreground" Value="{StaticResource DownBrush}"/>
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding IsTodayTradeValueStrong}" Value="True">
                                                                 <Setter Property="Foreground" Value="{StaticResource UpBrush}"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </TextBlock.Style>
                                             </TextBlock>
                                         </Grid>

                                         <TextBlock Grid.Row="0"
                                                    Grid.Column="1"
                                                    Text="{Binding CurrentPriceText}"
