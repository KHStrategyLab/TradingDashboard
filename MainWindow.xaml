                                                    FontWeight="Bold"
                                                    Foreground="{Binding PriceBrush}"
                                                    HorizontalAlignment="Right"
                                                    MinWidth="70"
                                                    TextAlignment="Right"/>

                                         <Grid Grid.Row="1"
                                               Grid.Column="1"
                                               HorizontalAlignment="Right"
                                               Margin="0,3,0,0">
