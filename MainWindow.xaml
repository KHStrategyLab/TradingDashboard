<Window x:Class="TradingDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TradingDashboard"
        Width="1920"
        Height="1080"
        MinWidth="1200"
        MinHeight="700"
        WindowState="Maximized"
        Background="#121212"
        Foreground="#E0E0E0"
        FontFamily="Malgun Gothic">

    <Window.Resources>
        <!-- 기존 프로그램 색상 팔레트 -->
        <!-- 중앙 팔레트 한곳에서 색상 관리 -->
        <SolidColorBrush x:Key="PaletteGreen" Color="#16A34A"/>
        <SolidColorBrush x:Key="PaletteLightGreen" Color="#86EFAC"/>
        <SolidColorBrush x:Key="PaletteBlue" Color="#1261C4"/>
        <SolidColorBrush x:Key="PaletteSkyBlue" Color="#38BDF8"/>
        <SolidColorBrush x:Key="PaletteRed" Color="#D92121"/>
        <SolidColorBrush x:Key="PalettePink" Color="#FF6B6B"/>
        <SolidColorBrush x:Key="PaletteYellow" Color="#EAB308"/>
        <SolidColorBrush x:Key="PaletteLightYellow" Color="#FDE68A"/>
        <SolidColorBrush x:Key="PaletteWhite" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PaletteBlueGray" Color="#64748B"/>
        <SolidColorBrush x:Key="PaletteOrange" Color="#F97316"/>
        <SolidColorBrush x:Key="PaletteViolet" Color="#8B5CF6"/>

        <!-- ?덇굅?????명솚 -->
        <SolidColorBrush x:Key="UpBrush" Color="#D92121"/>
        <SolidColorBrush x:Key="DownBrush" Color="#1261C4"/>
        <SolidColorBrush x:Key="FlatBrush" Color="#FFFFFF"/>

        <SolidColorBrush x:Key="AskBackground" Color="#FFF0F0"/>
        <SolidColorBrush x:Key="BidBackground" Color="#F0F8FF"/>
        <SolidColorBrush x:Key="HogaDividerBrush" Color="#64748B"/>

        <SolidColorBrush x:Key="OpenPriceBackground" Color="#ECFDF5"/>
        <SolidColorBrush x:Key="HighPriceBackground" Color="#FEE2E2"/>
        <SolidColorBrush x:Key="LowPriceBackground" Color="#DBEAFE"/>

        <SolidColorBrush x:Key="Ma5Brush" Color="#FF69B4"/>
        <SolidColorBrush x:Key="Ma10Brush" Color="#2563EB"/>
        <SolidColorBrush x:Key="Ma20Brush" Color="#FACC15"/>
        <SolidColorBrush x:Key="Ma60Brush" Color="#22C55E"/>
        <SolidColorBrush x:Key="Ma240Brush" Color="#F97316"/>
        <SolidColorBrush x:Key="Ma480Brush" Color="#8B5CF6"/>

        <!-- ?ㅽ겕 ?뚮쭏 ?붾젅??-->
        <SolidColorBrush x:Key="BgMainBrush" Color="#121212"/>
        <SolidColorBrush x:Key="BgPanelBrush" Color="#181818"/>
        <SolidColorBrush x:Key="BgHeaderBrush" Color="#252525"/>
        <SolidColorBrush x:Key="BgInnerBrush" Color="#151515"/>
        <SolidColorBrush x:Key="LineBrush" Color="#333333"/>
        <SolidColorBrush x:Key="LineSoftBrush" Color="#252525"/>

        <SolidColorBrush x:Key="TextMainBrush" Color="#DDDDDD"/>
        <SolidColorBrush x:Key="TextSubBrush" Color="#888888"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#777777"/>
        <SolidColorBrush x:Key="WhiteValueBrush" Color="#FFFFFF"/>

        <SolidColorBrush x:Key="OrderBookPriceBrush" Color="#AEB8C2"/>
        <SolidColorBrush x:Key="OrderBookQtyBrush" Color="#8FA0AF"/>
        <SolidColorBrush x:Key="CurrentUpBackgroundBrush" Color="#3A1E1E"/>
        <SolidColorBrush x:Key="CurrentDownBackgroundBrush" Color="#17243A"/>

        <Style x:Key="PanelHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
        </Style>

        <Style x:Key="PlaceholderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteValueBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#252525"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkMinuteComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteValueBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0">
                                <Grid>
                                    <ContentPresenter Margin="8,0,18,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"
                                                      Content="{Binding SelectedItem.Content, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <Path Width="8"
                                          Height="4"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Margin="0,0,7,0"
                                          Data="M 0 0 L 4 4 L 8 0 Z"
                                          Fill="{StaticResource TextMainBrush}"/>
                                </Grid>
                            </Border>

                            <ToggleButton Focusable="False"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="None">
                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#333333"
                                            BorderBrush="Transparent"
                                            BorderThickness="0">
                                        <ScrollViewer Margin="0"
                                                      CanContentScroll="True">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WatchListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#222222"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#252525"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NewsListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#222222"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#252525"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- ?곷떒 ?ㅻ뜑 -->
        <Border Grid.Row="0"
                Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="TradingDashboard"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="15,0,20,0"/>

                <TextBlock Grid.Column="1"
                           Text="관심종목 · 호가 · 체결 · 뉴스 · 공시"
                           FontSize="12"
                           Foreground="{StaticResource TextSubBrush}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,15,0">
                    <TextBlock Text="로컬 설정"
                               Foreground="{StaticResource TextSubBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3CB371"
                             VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 중앙 메인 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.725*"/>
                <ColumnDefinition Width="6.425*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- 왼쪽 종목 리스트 -->
            <Border Grid.Column="0"
                    Background="{StaticResource BgPanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="8*"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource BgHeaderBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="최근 조회 / 관심종목"
                                   Style="{StaticResource PanelHeaderTextStyle}"/>
                    </Border>

                    <ListBox Grid.Row="1"
                             x:Name="WatchListBox"
                             SelectionChanged="WatchListBox_SelectionChanged"
                             Background="{StaticResource BgPanelBrush}"
                             BorderThickness="0"
                             Foreground="{StaticResource WhiteValueBrush}"
                             ItemContainerStyle="{StaticResource WatchListBoxItemStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Height="54"
                                        BorderBrush="{StaticResource LineSoftBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="10,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                         <Grid Grid.Row="0"
                                               Grid.Column="0">
                                             <Grid.ColumnDefinitions>
                                                 <ColumnDefinition Width="*"/>
                                                 <ColumnDefinition Width="Auto"/>
                                                 <ColumnDefinition Width="Auto"/>
                                                 <ColumnDefinition Width="Auto"/>
                                             </Grid.ColumnDefinitions>

                                             <TextBlock Grid.Column="0"
                                                        Text="{Binding Name}"
                                                        FontSize="15"
                                                        FontWeight="Bold"
                                                        Foreground="{StaticResource WhiteValueBrush}"
                                                        TextTrimming="CharacterEllipsis"/>

                                             <Border Grid.Column="1"
                                                     Margin="6,2,0,0"
                                                     Padding="4,0"
                                                     MinWidth="34"
                                                     Height="14"
                                                     CornerRadius="3"
                                                     BorderBrush="{StaticResource PaletteBlueGray}"
                                                     BorderThickness="1"
                                                     Background="#1C232B"
                                                     VerticalAlignment="Center">
                                                 <Border.Style>
                                                     <Style TargetType="Border">
                                                         <Setter Property="Visibility" Value="Visible"/>
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding MarketBadgeText}" Value="">
                                                                 <Setter Property="Visibility" Value="Collapsed"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </Border.Style>
                                                 <TextBlock Text="{Binding MarketBadgeText}"
                                                            FontSize="8"
                                                            FontWeight="Bold"
                                                            Foreground="{StaticResource PaletteBlueGray}"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            TextAlignment="Center"/>
                                             </Border>

                                             <Border Grid.Column="2"
                                                     Margin="6,2,0,0"
                                                     Padding="0"
                                                     Width="26"
                                                     Height="14"
                                                     CornerRadius="3"
                                                     BorderBrush="{StaticResource PaletteSkyBlue}"
                                                     BorderThickness="1"
                                                     Background="#152A36"
                                                     VerticalAlignment="Center">
                                                 <Border.Style>
                                                     <Style TargetType="Border">
                                                         <Setter Property="Visibility" Value="Collapsed"/>
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding SupportsNxt}" Value="True">
                                                                 <Setter Property="Visibility" Value="Visible"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </Border.Style>
                                                 <TextBlock Text="NX"
                                                            FontSize="8"
                                                            FontWeight="Bold"
                                                            Foreground="{StaticResource PaletteSkyBlue}"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            TextAlignment="Center"/>
                                             </Border>

                                             <Border Grid.Column="3"
                                                     Margin="6,2,0,0"
                                                     Padding="4,0"
                                                     MinWidth="34"
                                                     Height="14"
                                                     CornerRadius="3"
                                                     BorderBrush="{StaticResource PaletteOrange}"
                                                     BorderThickness="1"
                                                     Background="#302315"
                                                     VerticalAlignment="Center">
                                                 <Border.Style>
                                                     <Style TargetType="Border">
                                                         <Setter Property="Visibility" Value="Visible"/>
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding AlertListBadgeText}" Value="">
                                                                 <Setter Property="Visibility" Value="Collapsed"/>
                                                             </DataTrigger>
                                                             <DataTrigger Binding="{Binding OrderWarning}" Value="5">
                                                                 <Setter Property="MinWidth" Value="34"/>
                                                                 <Setter Property="BorderBrush" Value="{StaticResource UpBrush}"/>
                                                                 <Setter Property="Background" Value="#351818"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </Border.Style>
                                                 <TextBlock Text="{Binding AlertListBadgeText}"
                                                            FontSize="8"
                                                            FontWeight="Bold"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             TextAlignment="Center">
                                                     <TextBlock.Style>
                                                         <Style TargetType="TextBlock">
                                                             <Setter Property="Foreground" Value="{StaticResource PaletteOrange}"/>
                                                             <Style.Triggers>
                                                                 <DataTrigger Binding="{Binding OrderWarning}" Value="5">
                                                                     <Setter Property="Foreground" Value="{StaticResource UpBrush}"/>
                                                                 </DataTrigger>
                                                             </Style.Triggers>
                                                         </Style>
                                                     </TextBlock.Style>
                                                 </TextBlock>
                                             </Border>
                                         </Grid>

                                         <TextBlock Grid.Row="1"
                                                    Grid.Column="0"
                                                    Text="{Binding VolumeText}"
                                                    FontSize="12"
                                                    Foreground="#A0A0A0"
                                                    Margin="0,3,0,0"
                                                    TextTrimming="CharacterEllipsis"/>

                                         <TextBlock Grid.Row="0"
                                                    Grid.Column="1"
                                                    Text="{Binding CurrentPriceText}"
                                                    FontSize="15"
                                                    FontWeight="Bold"
                                                    Foreground="{Binding PriceBrush}"
                                                    HorizontalAlignment="Right"
                                                    MinWidth="70"
                                                    TextAlignment="Right"/>

                                         <Grid Grid.Row="1"
                                               Grid.Column="1"
                                               HorizontalAlignment="Right"
                                               Margin="0,3,0,0">
                                             <Grid.ColumnDefinitions>
                                                 <ColumnDefinition Width="14"/>
                                                 <ColumnDefinition Width="54"/>
                                                 <ColumnDefinition Width="50"/>
                                             </Grid.ColumnDefinitions>
                                             <TextBlock Text="{Binding DirectionText}"
                                                        Grid.Column="0"
                                                        FontSize="11"
                                                        Foreground="{Binding PriceBrush}"
                                                        TextAlignment="Right"/>
                                             <TextBlock Text="{Binding ChangeAmountText}"
                                                        Grid.Column="1"
                                                        FontSize="12"
                                                        Foreground="{Binding PriceBrush}"
                                                        TextAlignment="Right"
                                                        Margin="0,0,6,0"/>
                                             <TextBlock Text="{Binding ChangeRateText}"
                                                        Grid.Column="2"
                                                        FontSize="12"
                                                        Foreground="{Binding PriceBrush}"
                                                        TextAlignment="Right"/>
                                         </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="2"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,1,0,0"
                            Background="{StaticResource BgInnerBrush}"
                            Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="로그"
                                       Foreground="{StaticResource TextMainBrush}"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>

                            <TextBox Grid.Row="1"
                                     x:Name="LeftLogTextBox"
                                     Margin="0,6,0,0"
                                     Background="#101010"
                                     Foreground="{StaticResource TextSubBrush}"
                                     BorderBrush="{StaticResource LineSoftBrush}"
                                     BorderThickness="1"
                                     FontSize="11"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- 중앙 차트 영역 -->
            <Border Grid.Column="1"
                    Background="{StaticResource BgPanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="6*"/>
                        <RowDefinition Height="1.5*"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource BgHeaderBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       x:Name="SelectedStockTitle"
                                       Text="TradingDashboard"
                                       Style="{StaticResource PanelHeaderTextStyle}"/>

                            <TextBlock Grid.Column="1"
                                       x:Name="SelectedStockSubInfo"
                                       Text="시가 - · 고가 - · 저가 - · 기준가 - · 거래대금 - · 회전율 - · 전일동시 -"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="20,0,0,0"/>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0">
                                <Button Content="월봉" Style="{StaticResource ToolbarButtonStyle}" Click="MonthChartButton_Click"/>
                                <Button Content="주봉" Style="{StaticResource ToolbarButtonStyle}" Click="WeekChartButton_Click"/>
                                <Button Content="일봉" Style="{StaticResource ToolbarButtonStyle}" Click="DayChartButton_Click"/>
                                <ComboBox x:Name="MinuteChartComboBox"
                                          Width="72"
                                          Height="24"
                                          Margin="4,0,0,0"
                                          SelectedValuePath="Tag"
                                          SelectedIndex="0"
                                          SelectionChanged="MinuteChartComboBox_SelectionChanged"
                                          DropDownOpened="MinuteChartComboBox_DropDownOpened"
                                          DropDownClosed="MinuteChartComboBox_DropDownClosed"
                                          Style="{StaticResource DarkMinuteComboBoxStyle}">
                                    <ComboBoxItem x:Name="MinuteChartPlaceholderItem" Content="분봉" Tag=""/>
                                    <ComboBoxItem Content="1분" Tag="Minute1"/>
                                    <ComboBoxItem Content="3분" Tag="Minute3"/>
                                    <ComboBoxItem Content="5분" Tag="Minute5"/>
                                    <ComboBoxItem Content="10분" Tag="Minute10"/>
                                    <ComboBoxItem Content="15분" Tag="Minute15"/>
                                    <ComboBoxItem Content="30분" Tag="Minute30"/>
                                    <ComboBoxItem Content="60분" Tag="Minute60"/>
                                    <ComboBoxItem Content="120분" Tag="Minute120"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10">
                        <Grid>
                            <Grid x:Name="MainChartHost"
                                  Background="{StaticResource BgMainBrush}"/>

                            <Border x:Name="StartupLoadingOverlay"
                                    Panel.ZIndex="10"
                                    Visibility="Collapsed"
                                    Background="#A0101010">
                                <Grid>
                                    <Border Width="230"
                                            Height="132"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="#202020"
                                            BorderBrush="{StaticResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="18">
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <Grid Width="48"
                                                  Height="48"
                                                  HorizontalAlignment="Center">
                                                <Ellipse Stroke="#343434"
                                                         StrokeThickness="4"/>
                                                <Path x:Name="StartupSpinnerArc"
                                                      Data="M 24,4 A20,20 0 0 1 44,24"
                                                      Stroke="{StaticResource PaletteSkyBlue}"
                                                      StrokeThickness="4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round">
                                                    <Path.RenderTransform>
                                                        <RotateTransform CenterX="24"
                                                                         CenterY="24"/>
                                                    </Path.RenderTransform>
                                                    <Path.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever">
                                                                    <DoubleAnimation Storyboard.TargetName="StartupSpinnerArc"
                                                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                     From="0"
                                                                                     To="360"
                                                                                     Duration="0:0:0.9"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Path.Triggers>
                                                </Path>
                                            </Grid>

                                            <TextBlock x:Name="StartupLoadingText"
                                                       Text="준비 중..."
                                                       Foreground="{StaticResource TextMainBrush}"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Margin="0,14,0,0"/>

                                            <TextBlock Text="잠시만 기다려줘"
                                                       Foreground="{StaticResource TextSubBrush}"
                                                       FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

