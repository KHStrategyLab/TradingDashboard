                                <ItemsControl x:Name="SellPriceListBox" Grid.Row="0" Grid.Column="2" Background="{StaticResource BgMainBrush}" ClipToBounds="True">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="10"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate><DataTemplate><Border BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1" Padding="0"><Border Background="{Binding CurrentPriceBackgroundBrush}" BorderThickness="0" Margin="2,1" Padding="0"><Border.Style><Style TargetType="Border"><Setter Property="Opacity" Value="1"/><Style.Triggers><DataTrigger Binding="{Binding IsCurrentPrice}" Value="True"><DataTrigger.EnterActions><BeginStoryboard><Storyboard RepeatBehavior="Forever" AutoReverse="True"><DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.48" To="0.78" Duration="0:0:0.55"/></Storyboard></BeginStoryboard></DataTrigger.EnterActions></DataTrigger></Style.Triggers></Style></Border.Style><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="34"/></Grid.ColumnDefinitions><TextBlock Grid.Column="1" Text="{Binding PriceText}" Foreground="{Binding PriceBrush}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding RateText}" Foreground="{Binding RateBrush}" FontSize="9" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="3,0,0,0"/></Grid></Border></Border></DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl x:Name="BuyPriceListBox" Grid.Row="1" Grid.Column="2" Background="{StaticResource BgMainBrush}" ClipToBounds="True">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="10"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate><DataTemplate><Border BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1" Padding="0"><Border Background="{Binding CurrentPriceBackgroundBrush}" BorderThickness="0" Margin="2,1" Padding="0"><Border.Style><Style TargetType="Border"><Setter Property="Opacity" Value="1"/><Style.Triggers><DataTrigger Binding="{Binding IsCurrentPrice}" Value="True"><DataTrigger.EnterActions><BeginStoryboard><Storyboard RepeatBehavior="Forever" AutoReverse="True"><DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.48" To="0.78" Duration="0:0:0.55"/></Storyboard></BeginStoryboard></DataTrigger.EnterActions></DataTrigger></Style.Triggers></Style></Border.Style><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="34"/></Grid.ColumnDefinitions><TextBlock Grid.Column="1" Text="{Binding PriceText}" Foreground="{Binding PriceBrush}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding RateText}" Foreground="{Binding RateBrush}" FontSize="9" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="3,0,0,0"/></Grid></Border></Border></DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl x:Name="BuyQtyListBox" Grid.Row="1" Grid.Column="3" Background="{StaticResource BgMainBrush}" ClipToBounds="True">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="10"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate><DataTemplate><Border BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1" Padding="0"><TextBlock Text="{Binding QtyText}" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/></Border></DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <Grid Grid.Row="2"
                                  Background="{StaticResource BgPanelBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="102"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="HogaStatusText" Grid.Column="0"
                                           Text="Price - / Rate - / 0D -"
                                           Foreground="{StaticResource TextMainBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"
                                           Visibility="Collapsed"/>

                                <TextBlock x:Name="HogaTotalSellText" Grid.Column="1"
                                           Text="0"
                                           Foreground="{StaticResource PaletteBlueGray}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,10,0"/>

                                <TextBlock x:Name="HogaDiffText" Grid.Column="2"
                                           Text="0"
                                           Foreground="{StaticResource PaletteBlueGray}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>

                                <TextBlock x:Name="HogaTotalBuyText" Grid.Column="3"
                                           Text="0"
                                           Foreground="{StaticResource PaletteBlueGray}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left"
                                           Margin="10,0,0,0"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10">
                        <Grid x:Name="TradeTickHost"
                              Background="{StaticResource BgInnerBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*"/>
                                <ColumnDefinition Width="6*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Trade prints -->
                            <Border Grid.Column="0"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="0,0,1,0"
                                    Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="22"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="Price"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="Qty"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <ListBox Grid.Row="1"
                                             x:Name="RecentTradeListBox"
                                             Background="{StaticResource BgInnerBrush}"
                                             BorderThickness="0"
                                             Focusable="False"
                                             IsHitTestVisible="False"
                                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource LineSoftBrush}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="0,2">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="1"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding PriceText}"
                                                                   Foreground="{Binding Color}"
                                                                   FontSize="12"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,8,0"/>
                                                        <Border Grid.Column="1"
                                                                Background="{StaticResource LineSoftBrush}"
                                                                Margin="0,1"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding QuantityText}"
                                                                   Foreground="{Binding QuantityColor}"
                                                                   FontSize="12"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Right"
                                                                   Margin="8,0,0,0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>

                            <!-- Stock metrics -->
                            <Border Grid.Column="1"
                                    Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Base" Foreground="{StaticResource TextSubBrush}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="InfoBasePriceText" Grid.Row="0" Grid.Column="1" Text="-" Foreground="{StaticResource WhiteValueBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Open" Foreground="{StaticResource TextSubBrush}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="InfoOpenPriceText" Grid.Row="1" Grid.Column="1" Text="-" Foreground="{StaticResource WhiteValueBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="High" Foreground="{StaticResource TextSubBrush}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="InfoHighPriceText" Grid.Row="2" Grid.Column="1" Text="-" Foreground="{StaticResource WhiteValueBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Low" Foreground="{StaticResource TextSubBrush}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="InfoLowPriceText" Grid.Row="3" Grid.Column="1" Text="-" Foreground="{StaticResource WhiteValueBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Value" Foreground="{StaticResource TextSubBrush}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="InfoTradingValueText" Grid.Row="4" Grid.Column="1" Text="-" Foreground="{StaticResource TextMainBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                    <TextBlock x:Name="InfoVolumeText" Grid.Row="4" Grid.Column="1" Text="-" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Turnover" Foreground="{StaticResource TextSubBrush}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="InfoTurnoverRateText" Grid.Row="5" Grid.Column="1" Text="-" Foreground="{StaticResource TextMainBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Prev-Time" Foreground="{StaticResource TextSubBrush}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="InfoPrevTimeVolumeRatioText" Grid.Row="6" Grid.Column="1" Text="-" Foreground="{StaticResource UpBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Buy Exec" Foreground="{StaticResource TextSubBrush}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="InfoBuyTradeVolumeText" Grid.Row="7" Grid.Column="1" Text="-" Foreground="{StaticResource UpBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Sell Exec" Foreground="{StaticResource TextSubBrush}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="InfoSellTradeVolumeText" Grid.Row="8" Grid.Column="1" Text="-" Foreground="{StaticResource DownBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Buy Ratio" Foreground="{StaticResource TextSubBrush}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="InfoBuyRatioText" Grid.Row="9" Grid.Column="1" Text="-" Foreground="{StaticResource UpBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Program" Foreground="{StaticResource TextSubBrush}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="InfoProgramText" Grid.Row="10" Grid.Column="1" Text="-" Foreground="{StaticResource UpBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Padding="10">
                        <Grid x:Name="StockInfoHost"
                              Background="{StaticResource BgInnerBrush}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="98"/>
                            </Grid.RowDefinitions>

                            <ListBox Grid.Row="0"
                                     x:Name="StockNewsListBox"
                                     Background="{StaticResource BgInnerBrush}"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextMainBrush}"
                                     ItemContainerStyle="{StaticResource NewsListBoxItemStyle}"
                                     MouseDoubleClick="OpenLinkedItem_MouseDoubleClick"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Hidden">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource LineSoftBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,5">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0"
                                                           Text="{Binding Title}"
                                                           Foreground="{StaticResource TextMainBrush}"
                                                           FontSize="13"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding PubDate}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="10"
                                                           Margin="0,3,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <ListBox Grid.Row="1"
                                     x:Name="StockDisclosureListBox"
                                     Background="{StaticResource BgPanelBrush}"
                                     BorderBrush="{StaticResource LineBrush}"
                                     BorderThickness="0,1,0,0"
                                     Foreground="{StaticResource TextMainBrush}"
                                     ItemContainerStyle="{StaticResource NewsListBoxItemStyle}"
                                     MouseDoubleClick="OpenLinkedItem_MouseDoubleClick"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Hidden">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource LineSoftBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="Filing"
                                                           Foreground="{StaticResource TextSubBrush}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"/>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Title}"
                                                           Foreground="{StaticResource TextMainBrush}"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding DateText}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
                    </TabItem>

                    <TabItem Header="News">
                        <Border Background="{StaticResource BgPanelBrush}"
                                Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0"
                                      Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock x:Name="MarketNewsStatusText"
                                               Grid.Column="0"
                                               Text="Market News"
                                               Foreground="{StaticResource TextSubBrush}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed"/>

                                    <TextBox Grid.Column="0"
                                             x:Name="MarketNewsSearchTextBox"
                                             Height="24"
                                             Margin="0,0,4,0"
                                             Background="#101010"
                                             BorderBrush="{StaticResource LineBrush}"
                                             BorderThickness="1"
                                             Foreground="{StaticResource TextMainBrush}"
                                             FontSize="12"
                                             Padding="6,2"
                                             VerticalContentAlignment="Center"
                                             ToolTip="News keyword search"
                                             KeyDown="MarketNewsSearchTextBox_KeyDown"/>

                                    <Button Grid.Column="1"
                                            x:Name="MarketNewsSearchButton"
                                            Content="Search"
                                            Width="52"
                                            Height="24"
                                            Style="{StaticResource ToolbarButtonStyle}"
                                            Click="MarketNewsSearchButton_Click"/>

                                    <Button Grid.Column="2"
                                            x:Name="MarketNewsRefreshButton"
                                            Content="Refresh"
                                            Width="76"
                                            Height="24"
                                            Margin="4,0,0,0"
                                            Style="{StaticResource ToolbarButtonStyle}"
                                            Click="MarketNewsRefreshButton_Click"/>
                                </Grid>

                                <ListBox Grid.Row="1"
                                         x:Name="MarketNewsListBox"
                                         Background="{StaticResource BgInnerBrush}"
                                         BorderBrush="{StaticResource LineBrush}"
                                         BorderThickness="1"
                                         Foreground="{StaticResource TextMainBrush}"
                                         ItemContainerStyle="{StaticResource NewsListBoxItemStyle}"
                                         MouseDoubleClick="OpenLinkedItem_MouseDoubleClick"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Hidden">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource LineSoftBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="10,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="74"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0"
                                                            Width="62"
                                                            Height="48"
                                                            Background="{StaticResource BgHeaderBrush}"
                                                            BorderBrush="{StaticResource LineBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="4"
                                                            VerticalAlignment="Top">
                                                        <Grid ClipToBounds="True">
                                                            <TextBlock Text="{Binding ThumbnailText}"
                                                                       Foreground="{StaticResource PaletteSkyBlue}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                            <Image Source="{Binding ThumbnailUrl}"
                                                                   Stretch="UniformToFill"/>
                                                        </Grid>
                                                    </Border>

                                                    <Grid Grid.Column="1">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Grid.Row="0"
                                                                   Text="{Binding Title}"
                                                                   Foreground="{StaticResource TextMainBrush}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"/>

                                                        <TextBlock Grid.Row="1"
                                                                   Text="{Binding Description}"
                                                                   Foreground="{StaticResource TextSubBrush}"
                                                                   FontSize="12"
                                                                   LineHeight="17"
                                                                   MaxHeight="34"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,4,0,0"/>

                                                        <StackPanel Grid.Row="2"
                                                                    Orientation="Horizontal"
                                                                    Margin="0,5,0,0">
                                                            <TextBlock Text="{Binding PubDate}"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       FontSize="11"/>
                                                            <TextBlock Text=" · "
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       FontSize="11"/>
                                                            <TextBlock Text="{Binding Source}"
                                                                       Foreground="{StaticResource PaletteBlueGray}"
                                                                       FontSize="11"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </TabItem>

                    <TabItem Header="Etc">
                        <Grid Background="{StaticResource BgPanelBrush}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1*"/>
                                <RowDefinition Height="3*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Margin="10"
                                    Padding="10"
                                    Background="{StaticResource BgInnerBrush}"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="Telegram Message"
                                               Foreground="{StaticResource TextMainBrush}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6"/>

                                    <TextBox Grid.Row="1"
                                             x:Name="TelegramManualTextBox"
                                             Background="#101010"
                                             BorderBrush="{StaticResource LineBrush}"
                                             BorderThickness="1"
                                             Foreground="{StaticResource TextMainBrush}"
                                             FontSize="12"
                                             Padding="6"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Hidden"
                                             KeyDown="TelegramManualTextBox_KeyDown"/>

                                    <Button Grid.Row="2"
                                            x:Name="TelegramManualSendButton"
                                            Content="Send"
                                            Width="76"
                                            Height="24"
                                            HorizontalAlignment="Right"
                                            Margin="0,8,0,0"
                                            Style="{StaticResource ToolbarButtonStyle}"
                                            Click="TelegramManualSendButton_Click"/>
                                </Grid>
                            </Border>

                            <TextBlock Grid.Row="1"
                                       Text="ETC panel"
                                       Style="{StaticResource PlaceholderTextStyle}"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <!-- Bottom status bar -->
        <Border Grid.Row="2"
                Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Status: Ready"
                           FontSize="12"
                           Foreground="{StaticResource TextSubBrush}"
                           VerticalAlignment="Center"
                           Margin="15,0,30,0"/>

                <TextBlock Grid.Column="1"
                           x:Name="MarketTickerText"
                            Text="KOSPI · KOSDAQ · Futures · FX · Signals"
                           FontSize="12"
                           Foreground="{StaticResource TextSubBrush}"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="2"
                           x:Name="ClockText"
                           Text="00:00:00"
                           FontSize="12"
                           Foreground="{StaticResource TextSubBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>

