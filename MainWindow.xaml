<Window x:Class="TradingDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TradingDashboard"
        Width="1920"
        Height="1080"
        MinWidth="1200"
        MinHeight="700"
        Icon="Assets/AppIcon.ico"
        WindowState="Maximized"
        Background="#121212"
        Foreground="#E0E0E0"
        FontFamily="Malgun Gothic"
        PreviewKeyDown="MainWindow_PreviewKeyDown">

    <Window.Resources>
        <!-- Legacy palette -->
        <!-- Centralized colors -->
        <SolidColorBrush x:Key="PaletteGreen" Color="#36be4d"/>
        <SolidColorBrush x:Key="PaletteLightGreen" Color="#86EFAC"/>
        <SolidColorBrush x:Key="PaletteBlue" Color="#6392d9"/>
        <SolidColorBrush x:Key="PaletteSkyBlue" Color="#3ec3fa"/>
        <SolidColorBrush x:Key="PaletteRed" Color="#f0332f"/>
        <SolidColorBrush x:Key="PalettePink" Color="#FF6B6B"/>
        <SolidColorBrush x:Key="PaletteYellow" Color="#EAB308"/>
        <SolidColorBrush x:Key="PaletteLightYellow" Color="#FDE68A"/>
        <SolidColorBrush x:Key="PaletteWhite" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PaletteBlueGray" Color="#b6ccd8"/>
        <SolidColorBrush x:Key="PaletteOrange" Color="#f09b3f"/>
        <SolidColorBrush x:Key="PaletteViolet" Color="#8B5CF6"/>

        <LinearGradientBrush x:Key="OffToggleTrackBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#666666" Offset="0"/>
            <GradientStop Color="#555555" Offset="0.52"/>
            <GradientStop Color="#444444" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SkyToggleTrackBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#6ED7FF" Offset="0"/>
            <GradientStop Color="#3EC3FA" Offset="0.52"/>
            <GradientStop Color="#229FD1" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="RedToggleTrackBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF6964" Offset="0"/>
            <GradientStop Color="#F0332F" Offset="0.52"/>
            <GradientStop Color="#C82320" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="YellowToggleTrackBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFECA8" Offset="0"/>
            <GradientStop Color="#EAB308" Offset="0.52"/>
            <GradientStop Color="#B77905" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="PowerPanelActiveBrush" Color="#801B1212"/>
        <SolidColorBrush x:Key="VirtualPanelActiveBrush" Color="#55302509"/>

        <!-- Price direction colors -->
        <SolidColorBrush x:Key="UpBrush" Color="#D92121"/>
        <SolidColorBrush x:Key="DownBrush" Color="#1261C4"/>
        <SolidColorBrush x:Key="FlatBrush" Color="#FFFFFF"/>

        <SolidColorBrush x:Key="AskBackground" Color="#FFF0F0"/>
        <SolidColorBrush x:Key="BidBackground" Color="#F0F8FF"/>
        <SolidColorBrush x:Key="HogaDividerBrush" Color="#64748B"/>

        <SolidColorBrush x:Key="OpenPriceBackground" Color="#ECFDF5"/>
        <SolidColorBrush x:Key="HighPriceBackground" Color="#FEE2E2"/>
        <SolidColorBrush x:Key="LowPriceBackground" Color="#DBEAFE"/>

        <SolidColorBrush x:Key="Ma5Brush" Color="#FF69B4"/>
        <SolidColorBrush x:Key="Ma10Brush" Color="#2563EB"/>
        <SolidColorBrush x:Key="Ma20Brush" Color="#FACC15"/>
        <SolidColorBrush x:Key="Ma60Brush" Color="#22C55E"/>
        <SolidColorBrush x:Key="Ma240Brush" Color="#F97316"/>
        <SolidColorBrush x:Key="Ma480Brush" Color="#8B5CF6"/>

        <!-- Dark theme palette -->
        <SolidColorBrush x:Key="BgMainBrush" Color="#121212"/>
        <SolidColorBrush x:Key="BgPanelBrush" Color="#181818"/>
        <SolidColorBrush x:Key="BgHeaderBrush" Color="#252525"/>
        <SolidColorBrush x:Key="BgInnerBrush" Color="#151515"/>
        <SolidColorBrush x:Key="LineBrush" Color="#333333"/>
        <SolidColorBrush x:Key="LineSoftBrush" Color="#252525"/>

        <SolidColorBrush x:Key="TextMainBrush" Color="#DDDDDD"/>
        <SolidColorBrush x:Key="TextSubBrush" Color="#888888"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#777777"/>
        <SolidColorBrush x:Key="WhiteValueBrush" Color="#FFFFFF"/>

        <SolidColorBrush x:Key="OrderBookPriceBrush" Color="#AEB8C2"/>
        <SolidColorBrush x:Key="OrderBookQtyBrush" Color="#8FA0AF"/>
        <SolidColorBrush x:Key="CurrentUpBackgroundBrush" Color="#3A1E1E"/>
        <SolidColorBrush x:Key="CurrentDownBackgroundBrush" Color="#17243A"/>

        <Style x:Key="PanelHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
        </Style>

        <Style x:Key="PlaceholderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteValueBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#252525"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkMinuteComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteValueBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0">
                                <Grid>
                                    <ContentPresenter Margin="8,0,18,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"
                                                      Content="{Binding SelectedItem.Content, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <Path Width="8"
                                          Height="4"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Margin="0,0,7,0"
                                          Data="M 0 0 L 4 4 L 8 0 Z"
                                          Fill="{StaticResource TextMainBrush}"/>
                                </Grid>
                            </Border>

                            <ToggleButton Focusable="False"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="None">
                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#333333"
                                            BorderBrush="Transparent"
                                            BorderThickness="0">
                                        <ScrollViewer Margin="0"
                                                      CanContentScroll="True">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WatchListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#172532"/>
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource PaletteSkyBlue}"/>
                                <Setter TargetName="ItemChrome" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#3EC3FA"
                                                          BlurRadius="8"
                                                          ShadowDepth="0"
                                                          Opacity="0.28"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#132838"/>
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource PaletteSkyBlue}"/>
                                <Setter TargetName="ItemChrome" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#3EC3FA"
                                                          BlurRadius="10"
                                                          ShadowDepth="0"
                                                          Opacity="0.35"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StockSearchSuggestionItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#20272D"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#172532"/>
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource PaletteSkyBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NewsListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#222222"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#252525"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RightPanelTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="{StaticResource BgPanelBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="RightPanelTabItemStyle" TargetType="{x:Type TabItem}">
            <Setter Property="Background" Value="{StaticResource BgHeaderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSubBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource BgPanelBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource WhiteValueBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#303030"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StrategySlotToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="SlotBorder"
                                Background="{StaticResource BgInnerBrush}"
                                BorderBrush="{StaticResource LineSoftBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="76"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter x:Name="SlotContent"
                                                  Grid.Column="0"
                                                  Margin="0,0,12,0"
                                                  VerticalAlignment="Center"/>

                                <Grid Grid.Column="1"
                                      Width="64"
                                      Height="28"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Top">
                                    <Border x:Name="SwitchTrack"
                                            Background="{StaticResource OffToggleTrackBrush}"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="14"/>
                                    <TextBlock x:Name="SwitchText"
                                               Text="OFF"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,10,0"/>
                                    <Border x:Name="SwitchThumb"
                                            Width="22"
                                            Height="22"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Margin="3,0,0,0"
                                            Background="{StaticResource PaletteWhite}"
                                            CornerRadius="11"/>
                                </Grid>

                                <TextBlock x:Name="SlotDisabledText"
                                           Grid.Column="0"
                                           Text="미적용"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Top"
                                           Margin="0,2,6,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SlotBorder" Property="BorderBrush" Value="{StaticResource PaletteSkyBlue}"/>
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{StaticResource SkyToggleTrackBrush}"/>
                                <Setter TargetName="SwitchText" Property="Text" Value="ON"/>
                                <Setter TargetName="SwitchText" Property="Foreground" Value="{StaticResource PaletteWhite}"/>
                                <Setter TargetName="SwitchText" Property="HorizontalAlignment" Value="Left"/>
                                <Setter TargetName="SwitchText" Property="Margin" Value="10,0,0,0"/>
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,3,0"/>
                                <Setter TargetName="SwitchThumb" Property="Background" Value="{StaticResource PaletteWhite}"/>
                                <Setter TargetName="SlotDisabledText" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="SlotContent" Property="Opacity" Value="0.48"/>
                                <Setter TargetName="SlotBorder" Property="BorderBrush" Value="#2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SlotBorder" Property="Background" Value="#1D2428"/>
                                <Setter TargetName="SlotBorder" Property="BorderBrush" Value="{StaticResource PaletteSkyBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StrategyDetailButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="DetailButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DetailButtonBorder" Property="Background" Value="#303840"/>
                                <Setter TargetName="DetailButtonBorder" Property="BorderBrush" Value="{StaticResource PaletteSkyBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StrategyStepCircleStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="CornerRadius" Value="11"/>
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="StrategyStepLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style x:Key="StrategyStrengthProgressBarStyle" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Foreground" Value="{StaticResource PaletteSkyBlue}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Grid x:Name="PART_Track"
                              SnapsToDevicePixels="True">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="10"/>
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="10"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StrategyStrengthLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextSubBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StrategyFilterChipStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="MinWidth" Value="86"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="13,0"/>
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="{StaticResource TextSubBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="ChipBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ChipBorder" Property="Background" Value="#14313D"/>
                                <Setter TargetName="ChipBorder" Property="BorderBrush" Value="{StaticResource PaletteSkyBlue}"/>
                                <Setter Property="Foreground" Value="{StaticResource PaletteSkyBlue}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChipBorder" Property="Background" Value="#303840"/>
                                <Setter TargetName="ChipBorder" Property="BorderBrush" Value="{StaticResource PaletteSkyBlue}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PolicyToggleSwitchStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="{StaticResource OffToggleTrackBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Grid>
                            <Border x:Name="SwitchTrack"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="0"
                                    CornerRadius="14"/>
                            <TextBlock x:Name="SwitchText"
                                       Text="OFF"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,10,0"/>
                            <Border x:Name="SwitchThumb"
                                    Width="22"
                                    Height="22"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="3,0,0,0"
                                    Background="{StaticResource PaletteWhite}"
                                    CornerRadius="11"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{StaticResource SkyToggleTrackBrush}"/>
                                <Setter TargetName="SwitchText" Property="Text" Value="ON"/>
                                <Setter TargetName="SwitchText" Property="Foreground" Value="{StaticResource PaletteWhite}"/>
                                <Setter TargetName="SwitchText" Property="HorizontalAlignment" Value="Left"/>
                                <Setter TargetName="SwitchText" Property="Margin" Value="10,0,0,0"/>
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,3,0"/>
                                <Setter TargetName="SwitchThumb" Property="Background" Value="{StaticResource PaletteWhite}"/>
