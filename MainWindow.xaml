        <Style x:Key="CardMutedTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ToggleButton}}}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource TextSubBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardSubTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextSubBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ToggleButton}}}" Value="True">
                    <Setter Property="Foreground" Value="#A8A8A8"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- Top header -->
        <Border Grid.Row="0"
                Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="TradingDashboard"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="15,0,20,0"/>

                <Grid Grid.Column="1"
                      Width="420"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="0"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="StockSearchTextBox"
                             Grid.Column="0"
                             Height="27"
                             Background="#101010"
                             Foreground="{StaticResource TextMainBrush}"
                             BorderBrush="{StaticResource LineSoftBrush}"
                             BorderThickness="1"
                             FontSize="12"
                             Padding="9,4"
                             VerticalContentAlignment="Center"
                             Text=""
                             TextChanged="StockSearchTextBox_TextChanged"
                             GotKeyboardFocus="StockSearchTextBox_GotKeyboardFocus"
                             PreviewMouseDown="StockSearchTextBox_PreviewMouseDown"
                             KeyDown="StockSearchTextBox_KeyDown"/>
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=StockSearchTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Canvas Width="14"
                                Height="14"
                                Margin="0,0,7,0"
                                VerticalAlignment="Center">
                            <Ellipse Width="8"
                                     Height="8"
                                     Stroke="{StaticResource TextMutedBrush}"
                                     StrokeThickness="1.4"
                                     Canvas.Left="1.5"
                                     Canvas.Top="1.5"/>
                            <Line X1="8.2"
                                  Y1="8.2"
                                  X2="12.6"
                                  Y2="12.6"
                                  Stroke="{StaticResource TextMutedBrush}"
                                  StrokeThickness="1.7"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Canvas>
                        <TextBlock Text="[Alt+S]"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button x:Name="StockSearchButton"
                            Grid.Column="1"
                            Content="Find"
                            Height="27"
                            Margin="6,0,0,0"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Visibility="Collapsed"
                            Click="StockSearchButton_Click"/>
                </Grid>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,15,0">
                    <TextBlock x:Name="StrategyRunLampText"
                               Text="WATCH OFF"
                               Foreground="{StaticResource TextSubBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <Ellipse x:Name="StrategyRunLampEllipse"
                             Width="9"
                             Height="9"
                             Fill="#656565"
                             VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <ListBox x:Name="StockSearchSuggestionListBox"
                 Grid.Row="0"
                 Grid.RowSpan="2"
                 Width="420"
                 Margin="0,39,0,0"
                 MaxHeight="170"
                 Panel.ZIndex="50"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Top"
                 Visibility="Collapsed"
                 Background="#181818"
                 BorderBrush="{StaticResource LineSoftBrush}"
                 BorderThickness="1"
                 Foreground="{StaticResource TextMainBrush}"
                 FocusVisualStyle="{x:Null}"
                 ItemContainerStyle="{StaticResource StockSearchSuggestionItemStyle}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                 MouseDoubleClick="StockSearchSuggestionListBox_MouseDoubleClick"
                 KeyDown="StockSearchSuggestionListBox_KeyDown">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8,5"
                            BorderBrush="{StaticResource LineSoftBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Code}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Name}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMainBrush}"
                                       MaxWidth="255"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding MarketName}"
                                       FontSize="10"
                                       Foreground="{StaticResource PaletteBlueGray}"
                                       Margin="8,0,0,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

