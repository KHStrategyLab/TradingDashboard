                                                         <Style TargetType="TextBlock">
                                                             <Setter Property="Foreground" Value="{StaticResource UpBrush}"/>
                                                             <Style.Triggers>
                                                                 <DataTrigger Binding="{Binding GateBaseCandleOffset}" Value="0">
                                                                     <Setter Property="Foreground" Value="{StaticResource PalettePink}"/>
                                                                 </DataTrigger>
                                                             </Style.Triggers>
                                                         </Style>
                                                     </TextBlock.Style>
