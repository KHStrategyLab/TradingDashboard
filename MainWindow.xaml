                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                         <Grid Grid.Row="0"
                                               Grid.Column="0">
                                             <Grid.ColumnDefinitions>
                                                 <ColumnDefinition Width="*"/>
                                                 <ColumnDefinition Width="Auto"/>
                                                 <ColumnDefinition Width="Auto"/>
                                                 <ColumnDefinition Width="Auto"/>
                                                 <ColumnDefinition Width="Auto"/>
                                                 <ColumnDefinition Width="Auto"/>
                                             </Grid.ColumnDefinitions>

                                             <TextBlock Grid.Column="0"
                                                        Text="{Binding Name}"
                                                        FontSize="15"
                                                        FontWeight="Bold"
                                                        Foreground="{StaticResource WhiteValueBrush}"
                                                        TextTrimming="CharacterEllipsis"/>

                                             <Border Grid.Column="1"
                                                     Margin="6,2,0,0"
                                                     Padding="4,0"
                                                     MinWidth="34"
                                                     Height="14"
                                                     CornerRadius="3"
                                                     BorderBrush="{StaticResource PaletteBlueGray}"
                                                     BorderThickness="1"
                                                     Background="#1C232B"
                                                     VerticalAlignment="Center">
                                                 <Border.Style>
                                                     <Style TargetType="Border">
                                                         <Setter Property="Visibility" Value="Visible"/>
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding MarketBadgeText}" Value="">
                                                                 <Setter Property="Visibility" Value="Collapsed"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </Border.Style>
                                                 <TextBlock Text="{Binding MarketBadgeText}"
                                                            FontSize="8"
                                                            FontWeight="Bold"
                                                            Foreground="{StaticResource PaletteBlueGray}"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            TextAlignment="Center"/>
                                             </Border>

                                             <Border Grid.Column="2"
                                                     Margin="6,2,0,0"
                                                     Padding="0"
                                                     Width="26"
                                                     Height="14"
                                                     CornerRadius="3"
                                                     BorderBrush="{StaticResource PaletteSkyBlue}"
                                                     BorderThickness="1"
                                                     Background="#152A36"
                                                     VerticalAlignment="Center">
                                                 <Border.Style>
                                                     <Style TargetType="Border">
                                                         <Setter Property="Visibility" Value="Collapsed"/>
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding SupportsNxt}" Value="True">
                                                                 <Setter Property="Visibility" Value="Visible"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </Border.Style>
                                                 <TextBlock Text="NX"
                                                            FontSize="8"
                                                            FontWeight="Bold"
                                                            Foreground="{StaticResource PaletteSkyBlue}"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            TextAlignment="Center"/>
                                             </Border>

                                             <Border Grid.Column="3"
                                                     Margin="6,2,0,0"
                                                     Padding="4,0"
                                                     MinWidth="34"
                                                     Height="14"
                                                     CornerRadius="3"
                                                     BorderBrush="{StaticResource PaletteOrange}"
                                                     BorderThickness="1"
                                                     Background="#302315"
                                                     VerticalAlignment="Center">
                                                 <Border.Style>
                                                     <Style TargetType="Border">
                                                         <Setter Property="Visibility" Value="Visible"/>
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding AlertListBadgeText}" Value="">
                                                                 <Setter Property="Visibility" Value="Collapsed"/>
                                                             </DataTrigger>
                                                             <DataTrigger Binding="{Binding OrderWarning}" Value="5">
                                                                 <Setter Property="MinWidth" Value="34"/>
                                                                 <Setter Property="BorderBrush" Value="{StaticResource UpBrush}"/>
                                                                 <Setter Property="Background" Value="#351818"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </Border.Style>
                                                 <TextBlock Text="{Binding AlertListBadgeText}"
                                                            FontSize="8"
                                                            FontWeight="Bold"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             TextAlignment="Center">
                                                     <TextBlock.Style>
                                                         <Style TargetType="TextBlock">
                                                             <Setter Property="Foreground" Value="{StaticResource PaletteOrange}"/>
                                                             <Style.Triggers>
                                                                 <DataTrigger Binding="{Binding OrderWarning}" Value="5">
                                                                     <Setter Property="Foreground" Value="{StaticResource UpBrush}"/>
                                                                 </DataTrigger>
                                                             </Style.Triggers>
                                                         </Style>
                                                     </TextBlock.Style>
                                                 </TextBlock>
                                             </Border>

                                             <Border Grid.Column="4"
                                                     Margin="6,2,0,0"
                                                     Padding="4,0"
                                                     MinWidth="30"
                                                     Height="14"
                                                     CornerRadius="3"
                                                     BorderBrush="{StaticResource PaletteSkyBlue}"
