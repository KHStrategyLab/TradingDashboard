                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#F0332F"
                                                                          BlurRadius="10"
                                                                          ShadowDepth="0"
                                                                          Opacity="0.32"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="64"/>
                                    </Grid.ColumnDefinitions>

                                    <ToggleButton x:Name="AutoTradingEnabledToggle"
                                                  Grid.Row="0"
                                                  Grid.ColumnSpan="2"
                                                  IsChecked="False"
                                                  Style="{StaticResource PowerCardToggleStyle}"
                                                  Checked="StrategyControlBoard_Changed"
                                                  Unchecked="StrategyControlBoard_Changed">
                                        <StackPanel>
                                                <Border HorizontalAlignment="Left"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="6,1">
                                                    <Border.Style>
                                                        <Style TargetType="{x:Type Border}">
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ToggleButton}}}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{StaticResource PaletteRed}"/>
                                                                    <Setter Property="Background" Value="#2A1515"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsChecked, ElementName=AutoTradingEnabledToggle}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{StaticResource PaletteRed}"/>
                                                                    <Setter Property="Background" Value="#2A1515"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="Engine Start"
                                                               FontSize="15"
                                                               FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="{x:Type TextBlock}">
                                                                <Setter Property="Foreground" Value="#9A3A3A"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ToggleButton}}}" Value="True">
                                                                        <Setter Property="Foreground" Value="{StaticResource PaletteRed}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsChecked, ElementName=AutoTradingEnabledToggle}" Value="True">
                                                                        <Setter Property="Foreground" Value="{StaticResource PaletteRed}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                                <TextBlock Text="Starts the strategy signal engine. Orders stay blocked until Live Orders is ON."
                                                           Style="{StaticResource CardMutedTextStyle}"
                                                           FontSize="11"
                                                           Margin="0,4,0,0"
                                                           TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ToggleButton>

                                    <ToggleButton x:Name="LiveBuyEnabledToggle"
                                                  Grid.Row="1"
                                                  Grid.ColumnSpan="2"
                                                  IsChecked="False"
                                                  Style="{StaticResource PowerCardToggleStyle}"
                                                  Checked="StrategyControlBoard_Changed"
                                                  Unchecked="StrategyControlBoard_Changed"
                                                  Margin="0,14,0,0">
                                        <StackPanel>
                                                <Border HorizontalAlignment="Left"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="6,1">
                                                    <Border.Style>
                                                        <Style TargetType="{x:Type Border}">
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ToggleButton}}}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{StaticResource PaletteRed}"/>
                                                                    <Setter Property="Background" Value="#2A1515"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsChecked, ElementName=LiveBuyEnabledToggle}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{StaticResource PaletteRed}"/>
                                                                    <Setter Property="Background" Value="#2A1515"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="Live Orders"
                                                               FontSize="15"
                                                               FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="{x:Type TextBlock}">
                                                                <Setter Property="Foreground" Value="#9A3A3A"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ToggleButton}}}" Value="True">
                                                                        <Setter Property="Foreground" Value="{StaticResource PaletteRed}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsChecked, ElementName=LiveBuyEnabledToggle}" Value="True">
                                                                        <Setter Property="Foreground" Value="{StaticResource PaletteRed}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                                <TextBlock Text="ON sends strategy signals to the live order layer. OFF keeps alerts and records only."
                                                           Style="{StaticResource CardMutedTextStyle}"
                                                           FontSize="10"
                                                           Margin="0,3,0,0"
                                                           TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ToggleButton>

                                    <Grid Grid.Row="2"
                                          Grid.ColumnSpan="2"
                                          Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="74"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0"
                                                    Margin="0,0,10,0">
                                            <TextBlock Text="예산"
                                                       Foreground="{StaticResource TextMainBrush}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"/>
                                                    <TextBox x:Name="AutoTradeBudgetTextBox"
                                                             Text="5,000,000"
                                                             Height="30"
                                                             Margin="0,5,0,0"
                                                             Padding="8,0"
                                                             TextChanged="StrategyControlBoardInput_Changed"
                                                             VerticalContentAlignment="Center">
                                                <TextBox.Style>
                                                    <Style TargetType="{x:Type TextBox}">
                                                        <Setter Property="Background" Value="#101010"/>
                                                        <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource LineSoftBrush}"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="FontSize" Value="13"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                        <Setter Property="CaretBrush" Value="{StaticResource PaletteRed}"/>
                                                        <Setter Property="SelectionBrush" Value="{StaticResource PaletteRed}"/>
                                                        <Setter Property="SelectionOpacity" Value="0.35"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="{x:Type TextBox}">
                                                                    <Border x:Name="TextBoxChrome"
                                                                            Background="{TemplateBinding Background}"
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="3"
                                                                            SnapsToDevicePixels="True">
                                                                        <ScrollViewer x:Name="PART_ContentHost"
                                                                                      Margin="{TemplateBinding Padding}"
                                                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="TextBoxChrome" Property="BorderBrush" Value="{StaticResource PaletteRed}"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                                            <Setter TargetName="TextBoxChrome" Property="BorderBrush" Value="{StaticResource PaletteRed}"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsEnabled" Value="False">
                                                                            <Setter TargetName="TextBoxChrome" Property="Opacity" Value="0.45"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="BorderBrush" Value="{StaticResource PaletteRed}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                                <Setter Property="BorderBrush" Value="{StaticResource PaletteRed}"/>
                                                            </Trigger>
                                                            <DataTrigger Binding="{Binding IsChecked, ElementName=AutoTradingEnabledToggle}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                <Setter Property="Opacity" Value="0.45"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="슬롯수"
                                                       Foreground="{StaticResource TextMainBrush}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"/>
                                                    <TextBox x:Name="AutoTradeSlotCountTextBox"
                                                             Text="3"
                                                             Height="30"
                                                             Margin="0,5,0,0"
                                                             Padding="8,0"
                                                             TextChanged="StrategyControlBoardInput_Changed"
                                                             TextAlignment="Center"
                                                     VerticalContentAlignment="Center">
                                                <TextBox.Style>
                                                    <Style TargetType="{x:Type TextBox}">
                                                        <Setter Property="Background" Value="#101010"/>
                                                        <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource LineSoftBrush}"/>
