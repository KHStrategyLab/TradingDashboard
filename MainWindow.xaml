                                                     <Style TargetType="Border">
                                                         <Setter Property="Visibility" Value="Visible"/>
                                                         <Setter Property="BorderBrush" Value="{StaticResource UpBrush}"/>
                                                         <Setter Property="Background" Value="#351818"/>
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding GateBaseCandleBadgeText}" Value="">
                                                                 <Setter Property="Visibility" Value="Collapsed"/>
                                                             </DataTrigger>
                                                             <DataTrigger Binding="{Binding GateBaseCandleOffset}" Value="0">
                                                                 <Setter Property="BorderBrush" Value="{StaticResource PalettePink}"/>
                                                                 <Setter Property="Background" Value="#4A161C"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </Border.Style>
                                                 <TextBlock Text="{Binding GateBaseCandleBadgeText}"
                                                            FontSize="8"
                                                            FontWeight="Bold"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            TextAlignment="Center">
