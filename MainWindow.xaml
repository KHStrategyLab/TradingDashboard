                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="매도체결" Foreground="{StaticResource TextSubBrush}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="InfoSellTradeVolumeText" Grid.Row="8" Grid.Column="1" Text="-" Foreground="{StaticResource DownBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="9" Grid.Column="0" Text="매수비율" Foreground="{StaticResource TextSubBrush}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="InfoBuyRatioText" Grid.Row="9" Grid.Column="1" Text="-" Foreground="{StaticResource UpBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="10" Grid.Column="0" Text="프로그램" Foreground="{StaticResource TextSubBrush}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="InfoProgramText" Grid.Row="10" Grid.Column="1" Text="-" Foreground="{StaticResource UpBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- 뉴스 / 공시 -->
                    <Border Grid.Row="3"
                            Padding="10">
                        <Grid x:Name="StockInfoHost"
                              Background="{StaticResource BgInnerBrush}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="98"/>
                            </Grid.RowDefinitions>

                            <ListBox Grid.Row="0"
                                     x:Name="StockNewsListBox"
                                     Background="{StaticResource BgInnerBrush}"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextMainBrush}"
                                     ItemContainerStyle="{StaticResource NewsListBoxItemStyle}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Hidden">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource LineSoftBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,5">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0"
                                                           Text="{Binding Title}"
                                                           Foreground="{StaticResource TextMainBrush}"
                                                           FontSize="11"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding PubDate}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="10"
                                                           Margin="0,3,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <ListBox Grid.Row="1"
                                     x:Name="StockDisclosureListBox"
                                     Background="{StaticResource BgPanelBrush}"
                                     BorderBrush="{StaticResource LineBrush}"
                                     BorderThickness="0,1,0,0"
                                     Foreground="{StaticResource TextMainBrush}"
                                     ItemContainerStyle="{StaticResource NewsListBoxItemStyle}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Hidden">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource LineSoftBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="공시"
                                                           Foreground="{StaticResource TextSubBrush}"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"/>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Title}"
                                                           Foreground="{StaticResource TextMainBrush}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding DateText}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="10"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- 하단 상태바 -->
        <Border Grid.Row="2"
                Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="상태: 화면 테스트 중"
                           FontSize="12"
                           Foreground="{StaticResource TextSubBrush}"
                           VerticalAlignment="Center"
                           Margin="15,0,30,0"/>

                <TextBlock Grid.Column="1"
                           x:Name="MarketTickerText"
                            Text="KOSPI · KOSDAQ · 선물 · 환율 · 신호 표시 영역"
                           FontSize="12"
                           Foreground="{StaticResource TextSubBrush}"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="2"
                           x:Name="ClockText"
                           Text="00:00:00"
                           FontSize="12"
                           Foreground="{StaticResource TextSubBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>

