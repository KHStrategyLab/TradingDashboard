<Window x:Class="TradingDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TradingDashboard"
        Width="1920"
        Height="1080"
        MinWidth="1200"
        MinHeight="700"
        Background="#121212"
        Foreground="#E0E0E0"
        FontFamily="Malgun Gothic">

    <Window.Resources>
        <!-- 기존 프로그램 색상 팔레트 -->
        <!-- 중앙 팔레트(한 곳에서 색상 관리) -->
        <SolidColorBrush x:Key="PaletteGreen" Color="#16A34A"/>
        <SolidColorBrush x:Key="PaletteLightGreen" Color="#86EFAC"/>
        <SolidColorBrush x:Key="PaletteBlue" Color="#1261C4"/>
        <SolidColorBrush x:Key="PaletteSkyBlue" Color="#38BDF8"/>
        <SolidColorBrush x:Key="PaletteRed" Color="#D92121"/>
        <SolidColorBrush x:Key="PalettePink" Color="#FF6B6B"/>
        <SolidColorBrush x:Key="PaletteYellow" Color="#EAB308"/>
        <SolidColorBrush x:Key="PaletteLightYellow" Color="#FDE68A"/>
        <SolidColorBrush x:Key="PaletteWhite" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PaletteBlueGray" Color="#64748B"/>
        <SolidColorBrush x:Key="PaletteOrange" Color="#F97316"/>
        <SolidColorBrush x:Key="PaletteViolet" Color="#8B5CF6"/>

        <!-- 레거시 키 호환 -->
        <SolidColorBrush x:Key="UpBrush" Color="#D92121"/>
        <SolidColorBrush x:Key="DownBrush" Color="#1261C4"/>
        <SolidColorBrush x:Key="FlatBrush" Color="#FFFFFF"/>

        <SolidColorBrush x:Key="AskBackground" Color="#FFF0F0"/>
        <SolidColorBrush x:Key="BidBackground" Color="#F0F8FF"/>
        <SolidColorBrush x:Key="HogaDividerBrush" Color="#64748B"/>

        <SolidColorBrush x:Key="OpenPriceBackground" Color="#ECFDF5"/>
        <SolidColorBrush x:Key="HighPriceBackground" Color="#FEE2E2"/>
        <SolidColorBrush x:Key="LowPriceBackground" Color="#DBEAFE"/>

        <SolidColorBrush x:Key="Ma5Brush" Color="#FF69B4"/>
        <SolidColorBrush x:Key="Ma10Brush" Color="#2563EB"/>
        <SolidColorBrush x:Key="Ma20Brush" Color="#FACC15"/>
        <SolidColorBrush x:Key="Ma60Brush" Color="#22C55E"/>

        <!-- 다크 테마 팔레트 -->
        <SolidColorBrush x:Key="BgMainBrush" Color="#121212"/>
        <SolidColorBrush x:Key="BgPanelBrush" Color="#181818"/>
        <SolidColorBrush x:Key="BgHeaderBrush" Color="#252525"/>
        <SolidColorBrush x:Key="BgInnerBrush" Color="#151515"/>
        <SolidColorBrush x:Key="LineBrush" Color="#333333"/>
        <SolidColorBrush x:Key="LineSoftBrush" Color="#252525"/>

        <SolidColorBrush x:Key="TextMainBrush" Color="#DDDDDD"/>
        <SolidColorBrush x:Key="TextSubBrush" Color="#888888"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#777777"/>
        <SolidColorBrush x:Key="WhiteValueBrush" Color="#FFFFFF"/>

        <SolidColorBrush x:Key="OrderBookPriceBrush" Color="#AEB8C2"/>
        <SolidColorBrush x:Key="OrderBookQtyBrush" Color="#8FA0AF"/>
        <SolidColorBrush x:Key="CurrentUpBackgroundBrush" Color="#3A1E1E"/>
        <SolidColorBrush x:Key="CurrentDownBackgroundBrush" Color="#17243A"/>

        <Style x:Key="PanelHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
        </Style>

        <Style x:Key="PlaceholderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="WatchListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#222222"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#252525"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NewsListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#222222"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#252525"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- 상단 헤더 -->
        <Border Grid.Row="0"
                Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="TradingDashboard"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="15,0,20,0"/>

                <TextBlock Grid.Column="1"
                           Text="관심종목 · 호가 · 체결 · 뉴스 · 공시"
                           FontSize="12"
                           Foreground="{StaticResource TextSubBrush}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,15,0">
                    <TextBlock Text="로컬 설정"
                               Foreground="{StaticResource TextSubBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3CB371"
                             VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 중앙 메인 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="6.65*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측 종목 리스트 -->
            <Border Grid.Column="0"
                    Background="{StaticResource BgPanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="8*"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource BgHeaderBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="최근 조회 / 관심종목"
                                   Style="{StaticResource PanelHeaderTextStyle}"/>
                    </Border>

                    <ListBox Grid.Row="1"
                             x:Name="WatchListBox"
                             SelectionChanged="WatchListBox_SelectionChanged"
                             Background="{StaticResource BgPanelBrush}"
                             BorderThickness="0"
                             Foreground="{StaticResource WhiteValueBrush}"
                             ItemContainerStyle="{StaticResource WatchListBoxItemStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Height="54"
                                        BorderBrush="{StaticResource LineSoftBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="10,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource WhiteValueBrush}"/>

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Text="{Binding VolumeText}"
                                                   FontSize="12"
                                                   Foreground="#A0A0A0"
                                                   Margin="0,3,0,0"/>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="1"
                                                   Text="{Binding CurrentPriceText}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding PriceBrush}"
                                                   HorizontalAlignment="Right"/>

                                        <StackPanel Grid.Row="1"
                                                    Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,3,0,0">
                                            <TextBlock Text="{Binding DirectionText}"
                                                       FontSize="11"
                                                       Foreground="{Binding PriceBrush}"/>
                                            <TextBlock Text="{Binding ChangeAmountText}"
                                                       FontSize="12"
                                                       Foreground="{Binding PriceBrush}"
                                                       Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding ChangeRateText}"
                                                       FontSize="12"
                                                       Foreground="{Binding PriceBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="2"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,1,0,0"
                            Background="{StaticResource BgInnerBrush}"
                            Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="로그"
                                       Foreground="{StaticResource TextMainBrush}"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>

                            <TextBox Grid.Row="1"
                                     x:Name="LeftLogTextBox"
                                     Margin="0,6,0,0"
                                     Background="#101010"
                                     Foreground="{StaticResource TextSubBrush}"
                                     BorderBrush="{StaticResource LineSoftBrush}"
                                     BorderThickness="1"
                                     FontSize="11"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- 중앙 차트 영역 -->
            <Border Grid.Column="1"
                    Background="{StaticResource BgPanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="6*"/>
                        <RowDefinition Height="1.5*"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource BgHeaderBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       x:Name="SelectedStockTitle"
                                       Text="삼성전자"
                                       Style="{StaticResource PanelHeaderTextStyle}"/>

                            <TextBlock Grid.Column="1"
                                       x:Name="SelectedStockSubInfo"
                                       Text="거래량 - · 거래대금 - · 시가총액 - · 유통주식수 - · 회전율 - · 주가등락률 - · 전일거래량대비 금일거래량 비율 -"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="20,0,0,0"/>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0">
                                <Button Content="월봉" Style="{StaticResource ToolbarButtonStyle}" Click="MonthChartButton_Click"/>
                                <Button Content="주봉" Style="{StaticResource ToolbarButtonStyle}" Click="WeekChartButton_Click"/>
                                <Button Content="일봉" Style="{StaticResource ToolbarButtonStyle}" Click="DayChartButton_Click"/>
                                <Button Content="3분" Style="{StaticResource ToolbarButtonStyle}" IsEnabled="False"/>
                                <Button Content="5분" Style="{StaticResource ToolbarButtonStyle}" IsEnabled="False"/>
                                <Button Content="15분" Style="{StaticResource ToolbarButtonStyle}" IsEnabled="False"/>
                                <Button Content="30분" Style="{StaticResource ToolbarButtonStyle}" IsEnabled="False"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10">
                        <Grid x:Name="MainChartHost"
                              Background="{StaticResource BgMainBrush}"/>
                    </Border>

                    <Border Grid.Row="2"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10">
                        <Grid x:Name="VolumeChartHost"
                              Background="{StaticResource BgInnerBrush}"/>
                    </Border>

                    <Border Grid.Row="3"
                            Padding="10">
                        <Grid x:Name="IndicatorChartHost"
                              Background="{StaticResource BgInnerBrush}">
                            <TextBlock Text="MACD / 이평 / 중심선 / 기준봉 보조지표 영역"
                                       Style="{StaticResource PlaceholderTextStyle}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- 우측 호가 / 체결 / 뉴스 -->
            <Border Grid.Column="2"
                    Background="{StaticResource BgPanelBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="4.4*"/>
                        <RowDefinition Height="2.4*"/>
                        <RowDefinition Height="3.2*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource BgHeaderBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="호가 / 체결 / 종목정보"
                                   Style="{StaticResource PanelHeaderTextStyle}"/>
                    </Border>

                    <!-- 10호가 -->
                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10">
                        <Grid x:Name="OrderBookHost"
                              Background="{StaticResource BgMainBrush}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="24"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0"
                                  Background="{StaticResource BgPanelBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="86"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="매도잔량"
                                           Foreground="{StaticResource TextSubBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           Text="호가"
                                           Foreground="{StaticResource TextSubBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>

                                <TextBlock Grid.Column="2"
                                           Text="매수잔량"
                                           Foreground="{StaticResource TextSubBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="86"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 매도 10호가 -->
                                <Border Grid.Row="0" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="2,841" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="317,500" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <Border Grid.Row="1" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="4,118" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="317,000" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <Border Grid.Row="2" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="7,304" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="316,500" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <Border Grid.Row="3" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="5,991" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="316,000" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <Border Grid.Row="4" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="9,420" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="315,500" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <Border Grid.Row="5" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="12,540" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="315,000" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <Border Grid.Row="6" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="8,911" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="314,500" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <Border Grid.Row="7" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="7" Grid.Column="0" Text="15,203" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="314,000" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <Border Grid.Row="8" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="8" Grid.Column="0" Text="6,784" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="313,500" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <Border Grid.Row="9" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="9" Grid.Column="0" Text="21,330" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                <Border Grid.Row="9"
                                        Grid.Column="1"
                                        Background="{StaticResource CurrentUpBackgroundBrush}"
                                        BorderBrush="{StaticResource UpBrush}"
                                        BorderThickness="2"
                                        CornerRadius="2"
                                        Margin="2">
                                    <TextBlock Text="313,000"
                                               Foreground="{StaticResource UpBrush}"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                </Border>

                                <!-- 매수 10호가 -->
                                <Border Grid.Row="10" Grid.ColumnSpan="3" Background="#161616" BorderBrush="#303030" BorderThickness="0,1,0,1"/>
                                <TextBlock Grid.Row="10" Grid.Column="1" Text="312,500" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="10" Grid.Column="2" Text="18,720" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>

                                <Border Grid.Row="11" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="11" Grid.Column="1" Text="312,000" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="11" Grid.Column="2" Text="23,401" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>

                                <Border Grid.Row="12" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="12" Grid.Column="1" Text="311,500" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="12" Grid.Column="2" Text="10,904" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>

                                <Border Grid.Row="13" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="13" Grid.Column="1" Text="311,000" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="13" Grid.Column="2" Text="7,881" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>

                                <Border Grid.Row="14" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="14" Grid.Column="1" Text="310,500" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="14" Grid.Column="2" Text="31,227" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>

                                <Border Grid.Row="15" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="15" Grid.Column="1" Text="310,000" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="15" Grid.Column="2" Text="14,105" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>

                                <Border Grid.Row="16" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="16" Grid.Column="1" Text="309,500" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="16" Grid.Column="2" Text="9,784" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>

                                <Border Grid.Row="17" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="17" Grid.Column="1" Text="309,000" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="17" Grid.Column="2" Text="16,772" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>

                                <Border Grid.Row="18" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="18" Grid.Column="1" Text="308,500" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="18" Grid.Column="2" Text="11,306" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>

                                <Border Grid.Row="19" Grid.ColumnSpan="3" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="19" Grid.Column="1" Text="308,000" Foreground="{StaticResource OrderBookPriceBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="19" Grid.Column="2" Text="27,991" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>
                            </Grid>

                            <Grid Grid.Row="1"
                                  Panel.ZIndex="10"
                                  Background="{StaticResource BgMainBrush}"
                                  ClipToBounds="True">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1*"/>
                                    <RowDefinition Height="1*"/>
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="86"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ItemsControl x:Name="SellQtyListBox" Grid.Row="0" Grid.Column="1" Background="{StaticResource BgMainBrush}" ClipToBounds="True">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="10"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate><DataTemplate><Border BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1" Padding="0"><TextBlock Text="{Binding QtyText}" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" TextAlignment="Right" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="0,0,10,0"/></Border></DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl x:Name="SellPriceListBox" Grid.Row="0" Grid.Column="2" Background="{StaticResource BgMainBrush}" ClipToBounds="True">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="10"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate><DataTemplate><Border BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1" Padding="0"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="34"/></Grid.ColumnDefinitions><TextBlock Grid.Column="1" Text="{Binding PriceText}" Foreground="{Binding PriceBrush}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding RateText}" Foreground="{Binding RateBrush}" FontSize="9" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="3,0,0,0"/></Grid></Border></DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl x:Name="BuyPriceListBox" Grid.Row="1" Grid.Column="2" Background="{StaticResource BgMainBrush}" ClipToBounds="True">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="10"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate><DataTemplate><Border BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1" Padding="0"><Grid VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="34"/></Grid.ColumnDefinitions><TextBlock Grid.Column="1" Text="{Binding PriceText}" Foreground="{Binding PriceBrush}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding RateText}" Foreground="{Binding RateBrush}" FontSize="9" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="3,0,0,0"/></Grid></Border></DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl x:Name="BuyQtyListBox" Grid.Row="1" Grid.Column="3" Background="{StaticResource BgMainBrush}" ClipToBounds="True">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="10"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate><DataTemplate><Border BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="0,0,0,1" Padding="0"><TextBlock Text="{Binding QtyText}" Foreground="{StaticResource OrderBookQtyBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/></Border></DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <Grid Grid.Row="2"
                                  Background="{StaticResource BgPanelBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="HogaStatusText" Grid.Column="0"
                                           Text="현재가 - / 등락률 - / 0D -"
                                           Foreground="{StaticResource TextMainBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>

                                <TextBlock x:Name="HogaSummaryText" Grid.Column="1"
                                           Text="총매도 0 · 총매수 0 · 차이 0"
                                           Foreground="{StaticResource UpBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,8,0"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- 최근 체결 / 종목 정보 -->
                    <Border Grid.Row="2"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10">
                        <Grid x:Name="TradeTickHost"
                              Background="{StaticResource BgInnerBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 최근 체결 -->
                            <Border Grid.Column="0"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="0,0,1,0"
                                    Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="22"/>
                                        <RowDefinition Height="18"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="최근 체결"
                                               Foreground="{StaticResource TextMainBrush}"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>

                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="체결가"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="수량"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <ListBox Grid.Row="2"
                                             x:Name="RecentTradeListBox"
                                             Background="{StaticResource BgInnerBrush}"
                                             BorderThickness="0"
                                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource LineSoftBrush}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="0,2">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="1"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding PriceText}"
                                                                   Foreground="{Binding Color}"
                                                                   FontSize="10"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,8,0"/>
                                                        <Border Grid.Column="1"
                                                                Background="{StaticResource LineSoftBrush}"
                                                                Margin="0,1"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding QuantityText}"
                                                                   Foreground="{Binding QuantityColor}"
                                                                   FontSize="10"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Right"
                                                                   Margin="8,0,0,0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>

                            <!-- 종목 정보 -->
                            <Border Grid.Column="1"
                                    Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="24"/>
                                        <RowDefinition Height="58"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="종목 정보"
                                               Foreground="{StaticResource TextMainBrush}"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>

                                    <Grid Grid.Row="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="시가" Foreground="{StaticResource TextSubBrush}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="InfoOpenPriceText" Grid.Row="0" Grid.Column="1" Text="-" Foreground="{StaticResource WhiteValueBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="6,0,10,0"/>

                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="고가" Foreground="{StaticResource TextSubBrush}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="InfoHighPriceText" Grid.Row="0" Grid.Column="3" Text="-" Foreground="{StaticResource WhiteValueBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="6,0,0,0"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="저가" Foreground="{StaticResource TextSubBrush}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="InfoLowPriceText" Grid.Row="1" Grid.Column="1" Text="-" Foreground="{StaticResource WhiteValueBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="6,0,10,0"/>

                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="기준가" Foreground="{StaticResource TextSubBrush}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="InfoBasePriceText" Grid.Row="1" Grid.Column="3" Text="-" Foreground="{StaticResource WhiteValueBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="6,0,0,0"/>
                                    </Grid>

                                    <Grid Grid.Row="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="거래대금" Foreground="{StaticResource TextSubBrush}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="InfoTradingValueText" Grid.Row="0" Grid.Column="1" Text="-" Foreground="{StaticResource TextMainBrush}" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="거래량" Foreground="{StaticResource TextSubBrush}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="InfoVolumeText" Grid.Row="1" Grid.Column="1" Text="-" Foreground="{StaticResource TextMainBrush}" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="전일거래량비" Foreground="{StaticResource TextSubBrush}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="InfoPrevTimeVolumeRatioText" Grid.Row="2" Grid.Column="1" Text="-" Foreground="{StaticResource UpBrush}" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="회전율" Foreground="{StaticResource TextSubBrush}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="InfoTurnoverRateText" Grid.Row="3" Grid.Column="1" Text="-" Foreground="{StaticResource TextMainBrush}" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="매도체결량" Foreground="{StaticResource TextSubBrush}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="InfoSellTradeVolumeText" Grid.Row="4" Grid.Column="1" Text="-" Foreground="{StaticResource DownBrush}" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="매수체결량" Foreground="{StaticResource TextSubBrush}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="InfoBuyTradeVolumeText" Grid.Row="5" Grid.Column="1" Text="-" Foreground="{StaticResource UpBrush}" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="매수비율" Foreground="{StaticResource TextSubBrush}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="InfoBuyRatioText" Grid.Row="6" Grid.Column="1" Text="-" Foreground="{StaticResource UpBrush}" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                        <TextBlock Grid.Row="7" Grid.Column="0" Text="프로그램" Foreground="{StaticResource TextSubBrush}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="InfoProgramText" Grid.Row="7" Grid.Column="1" Text="-" Foreground="{StaticResource UpBrush}" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- 뉴스 / 공시 -->
                    <Border Grid.Row="3"
                            Padding="10">
                        <Grid x:Name="StockInfoHost"
                              Background="{StaticResource BgInnerBrush}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="54"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0"
                                  Background="{StaticResource BgPanelBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="종목 뉴스 클리핑"
                                           Foreground="{StaticResource TextMainBrush}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>

                                <TextBlock Grid.Column="1"
                                           Text="뉴스 5개 / 공시 2개"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                            </Grid>

                            <ListBox Grid.Row="1"
                                     x:Name="StockNewsListBox"
                                     Background="{StaticResource BgInnerBrush}"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextMainBrush}"
                                     ItemContainerStyle="{StaticResource NewsListBoxItemStyle}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource LineSoftBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,5">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0"
                                                           Text="{Binding Title}"
                                                           Foreground="{StaticResource TextMainBrush}"
                                                           FontSize="11"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding PubDate}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="10"
                                                           Margin="0,3,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Border Grid.Row="2"
                                    Background="{StaticResource BgPanelBrush}"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="8,4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="공시"
                                               Foreground="{StaticResource TextSubBrush}"
                                               FontSize="10"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Text="최근 공시 1"
                                               Foreground="{StaticResource TextMainBrush}"
                                               FontSize="10"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Text="공시"
                                               Foreground="{StaticResource TextSubBrush}"
                                               FontSize="10"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="1"
                                               Text="최근 공시 2"
                                               Foreground="{StaticResource TextMainBrush}"
                                               FontSize="10"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- 하단 상태바 -->
        <Border Grid.Row="2"
                Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="상태: 화면 테스트 중"
                           FontSize="12"
                           Foreground="{StaticResource TextSubBrush}"
                           VerticalAlignment="Center"
                           Margin="15,0,30,0"/>

                <TextBlock Grid.Column="1"
                           x:Name="MarketTickerText"
                           Text="KOSPI · KOSDAQ · 선물 · 환율 · 유가 표시 영역"
                           FontSize="12"
                           Foreground="{StaticResource TextSubBrush}"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="2"
                           x:Name="ClockText"
                           Text="00:00:00"
                           FontSize="12"
                           Foreground="{StaticResource TextSubBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
