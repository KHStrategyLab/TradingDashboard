                            <ListBox x:Name="RecentWatchListBox"
                                     SelectionChanged="WatchListBox_SelectionChanged"
                                     Background="{StaticResource BgPanelBrush}"
                                     BorderThickness="0"
                                     Foreground="{StaticResource WhiteValueBrush}"
                                     ItemContainerStyle="{StaticResource WatchListBoxItemStyle}"
                                     ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Height="48"
                                                BorderBrush="{StaticResource LineSoftBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="10,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="100"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource WhiteValueBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding VolumeText}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               Margin="0,3,0,0"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1"
                                                            HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding CurrentPriceText}"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Foreground="{Binding PriceBrush}"
                                                               TextAlignment="Right"/>
                                                    <TextBlock Text="{Binding ChangeRateText}"
                                                               FontSize="11"
                                                               Foreground="{Binding PriceBrush}"
                                                               Margin="0,3,0,0"
                                                               TextAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            </Grid>
                        </TabItem>
                    </TabControl>

                    <Border Grid.Row="2"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,1,0,0"
                            Background="{StaticResource BgInnerBrush}"
                            Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Log"
                                       Foreground="{StaticResource TextMainBrush}"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>

                            <RichTextBox Grid.Row="1"
                                         x:Name="LeftLogTextBox"
                                         Margin="0,6,0,0"
                                         Background="#101010"
                                         Foreground="{StaticResource TextSubBrush}"
                                         BorderBrush="{StaticResource LineSoftBrush}"
                                         BorderThickness="1"
                                         FontSize="11"
                                         IsReadOnly="True"
                                         VerticalScrollBarVisibility="Hidden"
                                         HorizontalScrollBarVisibility="Disabled"
                                         MouseDoubleClick="LeftLogTextBox_MouseDoubleClick">
                                <FlowDocument PagePadding="4,3,4,3"/>
                            </RichTextBox>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Center chart area -->
            <Border Grid.Column="1"
                    Background="{StaticResource BgPanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="6*"/>
                        <RowDefinition Height="1.5*"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource BgHeaderBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       x:Name="SelectedStockTitle"
                                       Text="TradingDashboard"
                                       Style="{StaticResource PanelHeaderTextStyle}"/>

                            <TextBlock Grid.Column="1"
                                       x:Name="SelectedStockSubInfo"
                                       Text="Open - · High - · Low - · Base - · Value - · Turnover - · Prev-Time -"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="20,0,0,0"/>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0">
                        <Button Content="Month" Width="60" Style="{StaticResource ToolbarButtonStyle}" Click="MonthChartButton_Click"/>
                        <Button Content="Week" Width="56" Style="{StaticResource ToolbarButtonStyle}" Click="WeekChartButton_Click"/>
                        <Button Content="Day" Width="48" Style="{StaticResource ToolbarButtonStyle}" Click="DayChartButton_Click"/>
                                <ComboBox x:Name="MinuteChartComboBox"
                                          Width="82"
                                          Height="24"
                                          Margin="4,0,0,0"
                                          SelectedValuePath="Tag"
                                          SelectedIndex="0"
                                          SelectionChanged="MinuteChartComboBox_SelectionChanged"
                                          DropDownOpened="MinuteChartComboBox_DropDownOpened"
                                          DropDownClosed="MinuteChartComboBox_DropDownClosed"
                                          Style="{StaticResource DarkMinuteComboBoxStyle}">
                                    <ComboBoxItem x:Name="MinuteChartPlaceholderItem" Content="Min" Tag=""/>
                                    <ComboBoxItem Content="1min" Tag="Minute1"/>
                                    <ComboBoxItem Content="3min" Tag="Minute3"/>
                                    <ComboBoxItem Content="5min" Tag="Minute5"/>
                                    <ComboBoxItem Content="10min" Tag="Minute10"/>
                                    <ComboBoxItem Content="15min" Tag="Minute15"/>
                                    <ComboBoxItem Content="30min" Tag="Minute30"/>
                                    <ComboBoxItem Content="60min" Tag="Minute60"/>
                                    <ComboBoxItem Content="120min" Tag="Minute120"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10">
                        <Grid>
                            <Grid x:Name="MainChartHost"
                                  Background="{StaticResource BgMainBrush}"/>

                            <Border x:Name="StartupLoadingOverlay"
                                    Panel.ZIndex="10"
                                    Visibility="Collapsed"
                                    Background="#A0101010">
                                <Grid>
                                    <Border Width="460"
                                            Height="264"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="#202020"
                                            BorderBrush="{StaticResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="32">
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <Grid Width="96"
                                                  Height="96"
                                                  HorizontalAlignment="Center">
                                                <Ellipse Stroke="#343434"
                                                         StrokeThickness="8"/>
                                                <Path x:Name="StartupSpinnerArc"
                                                      Data="M 48,8 A40,40 0 0 1 88,48"
                                                      Stroke="{StaticResource PaletteSkyBlue}"
                                                      StrokeThickness="8"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round">
                                                    <Path.RenderTransform>
                                                        <RotateTransform CenterX="48"
                                                                         CenterY="48"/>
                                                    </Path.RenderTransform>
                                                    <Path.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever">
                                                                    <DoubleAnimation Storyboard.TargetName="StartupSpinnerArc"
                                                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                     From="0"
                                                                                     To="360"
                                                                                     Duration="0:0:0.9"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Path.Triggers>
                                                </Path>
                                            </Grid>

                                            <TextBlock x:Name="StartupLoadingText"
                                                       Text="Loading..."
                                                       Foreground="{StaticResource TextMainBrush}"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Margin="0,24,0,0"/>

                                            <StackPanel Margin="0,12,0,0"
                                                        Width="360">
                                                <TextBlock x:Name="StartupStatusLine1Text"
                                                           Text="Preparing workspace..."
                                                           Foreground="{StaticResource TextSubBrush}"
                                                           FontSize="12"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock x:Name="StartupStatusLine2Text"
                                                           Text="Waiting for first market data"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10">
                        <Grid x:Name="VolumeChartHost"
                              Background="{StaticResource BgInnerBrush}"/>
                    </Border>

                    <Border Grid.Row="3"
                            Padding="10">
                        <Grid x:Name="IndicatorChartHost"
                              Background="{StaticResource BgInnerBrush}">
                            <TextBlock Text="MACD / MA / centerline / base candle indicators"
                                       Style="{StaticResource PlaceholderTextStyle}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource BgPanelBrush}">
                <TabControl Style="{StaticResource RightPanelTabControlStyle}"
                            ItemContainerStyle="{StaticResource RightPanelTabItemStyle}">
                    <TabItem Header="Strategy">
                        <Grid Background="{StaticResource BgPanelBrush}"
                              Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="14"
                                    MinHeight="126"
                                    Margin="0,0,0,12">
                                <Border.Style>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="Background" Value="{StaticResource BgInnerBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
                                        <Setter Property="Effect" Value="{x:Null}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, ElementName=AutoTradingEnabledToggle}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource PowerPanelActiveBrush}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource PaletteRed}"/>
